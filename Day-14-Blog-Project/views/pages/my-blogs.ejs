<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Manage your blog posts on BlogSphere.">
    <title>My Blogs — BlogSphere</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="../../assets/css/styles.css" rel="stylesheet">
</head>

<body>

    <div class="dashboard-wrapper">
        <aside class="dashboard-sidebar">
            <div class="sidebar-brand"><i class="bi bi-globe2 me-2"></i>BlogSphere</div>
            <div class="sidebar-section-title">Main Menu</div>
            <nav class="sidebar-nav">
                <a href="dashboard.html" class="nav-link"><i class="bi bi-speedometer2"></i> Dashboard</a>
                <a href="create-blog.html" class="nav-link"><i class="bi bi-plus-circle"></i> Create Blog</a>
                <a href="my-blogs.html" class="nav-link active"><i class="bi bi-journal-text"></i> My Blogs</a>
                <a href="profile-settings.html" class="nav-link"><i class="bi bi-person-gear"></i> Profile &
                    Settings</a>
            </nav>
            <div class="sidebar-section-title">Quick Links</div>
            <nav class="sidebar-nav">
                <a href="../../index.html" class="nav-link"><i class="bi bi-house"></i> Back to Home</a>
            </nav>
        </aside>

        <div class="dashboard-content">
            <div class="dashboard-topbar">
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-ghost d-lg-none" onclick="toggleSidebar()"><i class="bi bi-list"
                            style="font-size:22px;"></i></button>
                    <div class="topbar-title">
                        <h4>My Blogs</h4>
                        <p>Manage your articles</p>
                    </div>
                </div>
                <div class="topbar-actions">
                    <a href="create-blog.html" class="btn btn-gradient"><i class="bi bi-plus me-1"></i> New Blog</a>
                </div>
            </div>

            <div class="dashboard-main">
                <!-- Filters -->
                <div class="card-custom p-3 mb-4 fade-in">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                        <div class="d-flex gap-2">
                            <button class="btn btn-gradient btn-sm" data-filter="all">All</button>
                            <button class="btn btn-ghost btn-sm" data-filter="published">Published</button>
                            <button class="btn btn-ghost btn-sm" data-filter="draft">Drafts</button>
                            <button class="btn btn-ghost btn-sm" data-filter="pending">Pending</button>
                        </div>
                        <div class="search-bar" style="max-width:300px;">
                            <i class="bi bi-search"></i>
                            <input type="text" id="blogSearch" placeholder="Search my blogs..." class="form-control"
                                style="padding:10px 16px 10px 40px; font-size:14px;">
                        </div>
                    </div>
                </div>

                <!-- Blog List -->
                <div id="blogList" class="fade-in">
                    <!-- Rendered by JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:var(--radius-modal); border:none;">
                <div class="modal-body text-center p-5">
                    <div
                        style="width:72px; height:72px; border-radius:50%; background:rgba(231,76,60,0.1); display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
                        <i class="bi bi-trash" style="font-size:32px; color:var(--clr-error);"></i>
                    </div>
                    <h4>Delete Blog?</h4>
                    <p class="text-muted-custom">This action cannot be undone. The blog post will be permanently
                        removed.</p>
                    <div class="d-flex gap-2 justify-content-center mt-4">
                        <button class="btn btn-ghost border px-4" data-bs-dismiss="modal">Cancel</button>
                        <button class="btn px-4"
                            style="background:var(--clr-error); color:#fff; border-radius:var(--radius-btn);"
                            id="confirmDelete">Delete</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="toastContainer" style="position:fixed; top:80px; right:20px; z-index:9999; width:360px;"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const user = userModel.getCurrentUser();
            let currentFilter = 'all';
            let searchQuery = '';
            let deleteBlogId = null;

            function renderBlogs() {
                let blogs = blogModel.getByAuthor(user.id);

                if (currentFilter !== 'all') {
                    blogs = blogs.filter(b => b.status === currentFilter);
                }
                if (searchQuery) {
                    blogs = blogs.filter(b => b.title.toLowerCase().includes(searchQuery));
                }

                const list = document.getElementById('blogList');
                if (blogs.length === 0) {
                    list.innerHTML = `<div class="empty-state"><i class="bi bi-journal-x"></i><h4>No blogs found</h4><p>You haven't written any blogs yet.</p><a href="create-blog.html" class="btn btn-gradient">Write Your First Blog</a></div>`;
                    return;
                }

                list.innerHTML = blogs.map(b => {
                    const cat = categoryModel.getById(b.categoryId);
                    const statusClass = b.status === 'published' ? 'badge-published' : b.status === 'draft' ? 'badge-draft' : 'badge-pending';
                    return `
            <div class="card-custom p-4 mb-3" style="transition:var(--transition);">
              <div class="d-flex gap-4 align-items-start flex-wrap">
                <img src="${b.image}" style="width:140px; height:100px; object-fit:cover; border-radius:var(--radius-btn); flex-shrink:0;" alt="${b.title}">
                <div style="flex:1; min-width:200px;">
                  <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge-custom ${statusClass}">${b.status}</span>
                    ${cat ? `<span class="text-small text-muted-custom"><i class="bi bi-folder me-1"></i>${cat.name}</span>` : ''}
                  </div>
                  <h5 style="font-size:18px; margin-bottom:6px;">
                    <a href="single-blog.html?id=${b.id}" style="color:var(--clr-text);">${b.title}</a>
                  </h5>
                  <p class="text-small text-muted-custom mb-2">${truncate(b.excerpt, 150)}</p>
                  <div class="d-flex gap-4 text-small text-muted-custom">
                    <span><i class="bi bi-calendar me-1"></i>${formatDate(b.createdAt)}</span>
                    <span><i class="bi bi-clock me-1"></i>${b.readTime}</span>
                    <span><i class="bi bi-eye me-1"></i>${formatNumber(b.views)}</span>
                    <span><i class="bi bi-heart me-1"></i>${b.likes}</span>
                    <span><i class="bi bi-chat me-1"></i>${b.commentsCount}</span>
                  </div>
                </div>
                <div class="d-flex gap-2 flex-shrink-0 align-self-center">
                  <a href="edit-blog.html?id=${b.id}" class="btn-icon" title="Edit"><i class="bi bi-pencil"></i></a>
                  <a href="single-blog.html?id=${b.id}" class="btn-icon" title="View"><i class="bi bi-eye"></i></a>
                  <button class="btn-icon delete-btn" data-id="${b.id}" title="Delete"><i class="bi bi-trash"></i></button>
                </div>
              </div>
            </div>`;
                }).join('');

                // Attach delete handlers
                list.querySelectorAll('.delete-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        deleteBlogId = parseInt(btn.dataset.id);
                        new bootstrap.Modal(document.getElementById('deleteModal')).show();
                    });
                });
            }

            // Filter buttons
            document.querySelectorAll('[data-filter]').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('[data-filter]').forEach(b => { b.className = 'btn btn-ghost btn-sm'; });
                    btn.className = 'btn btn-gradient btn-sm';
                    currentFilter = btn.dataset.filter;
                    renderBlogs();
                });
            });

            // Search
            document.getElementById('blogSearch').addEventListener('input', (e) => {
                searchQuery = e.target.value.toLowerCase().trim();
                renderBlogs();
            });

            // Confirm delete
            document.getElementById('confirmDelete').addEventListener('click', () => {
                bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
                showToast('Blog deleted successfully', 'success');
                renderBlogs();
            });

            renderBlogs();
        });
    </script>
</body>

</html>